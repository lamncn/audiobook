{"id":"script_9","mode":"function","name":"truyenso1.com","domain":"truyenso1.com","getcontent": "var chaptertitle = document.getElementsByClassName('chapter-title')[0].textContent.trim(); var element = document.getElementsByClassName('chapter-content')[0]; element.querySelectorAll('div').forEach(el => el.remove()); element.querySelectorAll('i').forEach(el => el.remove()); element.querySelectorAll('p[class]').forEach(el => el.remove()); var chaptercontent = chaptertitle + '\\n' + element.innerText; chaptercontent = chaptercontent.replace(/<br class=\"html-br\">/ig, '\\n').replace(/\\·/ig, '').replace(/\\<em\\>/ig, '').replace(/\\<\\/em\\>/ig, '').replace(/\\<p\\>/ig, '\\n').replace(/\\<\\/p\\>/ig, '\\n').replace(/&nbsp;/ig, ' ').replace(/[ ]+/ig, ' ').replace(/<br>/ig, '\\n').replace(/<div>/ig, '\\n').replace(/<\\/div>/ig, '\\n').replace(/\\s*\\n\\s*/ig, '\\n\\n').trim(); return chaptercontent;", "gonext":"document.getElementById('next_chap').click();","nextButtonSelector":"","nextButtonText":"","blacklistedSelectors":[],"whitelistedSelectors":[],"removeSelectors":[],"createdAt":"2026-05-28T18:34:06.474617"},


