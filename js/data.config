{"id":"script_4","mode":"function","name":"tangthuvien.org","domain":"tangthuvien.org","getcontent": "const h1 = document.querySelector('h1'); h1.querySelector('span')?.remove(); var chaptertitle = h1.textContent.trim(); var element = document.getElementsByClassName('flex-col gap-4')[0]; element.querySelectorAll('div').forEach(el => el.remove()); element.querySelectorAll('i').forEach(el => el.remove()); element.querySelectorAll('p[class]').forEach(el => el.remove()); var chaptercontent = chaptertitle + '\\n' + element.innerHTML; chaptercontent = chaptercontent.replace(/\\·/ig, '').replace(/\\<em\\>/ig, '').replace(/\\<\\/em\\>/ig, '').replace(/\\<p\\>/ig, '\\n').replace(/\\<\\/p\\>/ig, '\\n').replace(/&nbsp;/ig, ' ').replace(/[ ]+/ig, ' ').replace(/<br>/ig, '\\n').replace(/<div>/ig, '\\n').replace(/<\\/div>/ig, '\\n').replace(/\\s*\\n\\s*/ig, '\\n\\n').trim(); return chaptercontent;", "gonext":"var button = Array.from(document.body.querySelectorAll('a')).findLast(elm => elm.textContent.toLowerCase().includes('chương tiếp')); document.location.href = button.href;","nextButtonSelector":"","nextButtonText":"","blacklistedSelectors":[],"whitelistedSelectors":[],"removeSelectors":[],"createdAt":"2026-05-28T18:34:06.474617"},


